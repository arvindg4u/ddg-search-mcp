# MCP Authentication Token
# Clients must include this in the Authorization header:
#   Authorization: Bearer YOUR_TOKEN
# Leave unset to disable authentication (local dev only).
MCP_API_TOKEN=

# Server port (default: 10000)
PORT=10000

# DuckDuckGo search timeout in seconds (default: 10)
DDGS_TIMEOUT=10

# DuckDuckGo proxy (optional, e.g. http://user:pass@host:port or "tb" for Tor)
DDGS_PROXY=
